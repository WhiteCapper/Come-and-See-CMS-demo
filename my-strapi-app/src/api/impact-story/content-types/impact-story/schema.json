{
  "kind": "collectionType",
  "collectionName": "impact_stories",
  "info": {
    "singularName": "impact-story",
    "pluralName": "impact-stories",
    "displayName": "impact-story"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "media": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "tags": {
      "type": "json"
    },
    "season": {
      "type": "integer"
    },
    "fullStory": {
      "type": "text",
      "required": true
    }
  }
}
